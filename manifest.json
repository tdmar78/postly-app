// ─── Onboarding questions ────────────────────────────────────────────────────
const ONBOARDING_QUESTIONS = [
  { id: "businessName",   label: "Business Name",           placeholder: "e.g. Bella's Bistro",           required: true },
  { id: "ownerName",      label: "Owner / Contact Name",    placeholder: "e.g. Sofia Conti",              required: true },
  { id: "businessType",   label: "Business Type",           placeholder: "e.g. Italian Restaurant",       required: true },
  { id: "city",           label: "City / Location",         placeholder: "e.g. Austin, TX",               required: true },
  { id: "differentiator", label: "What makes them special", placeholder: "e.g. Fresh pasta made daily",   required: true },
  { id: "targetCustomer", label: "Ideal customer",          placeholder: "e.g. Couples, foodies aged 28–45", required: true },
  { id: "brandVibe",      label: "Brand vibe",              placeholder: "e.g. Warm, old-world Italian",  required: true },
  { id: "platform",       label: "Primary platform",        placeholder: "e.g. Instagram",                required: true },
  { id: "promotions",     label: "Upcoming promotions",     placeholder: "e.g. Valentine's menu, Sunday brunch launch", required: false },
  { id: "avoidWords",     label: "Words to NEVER use",      placeholder: "e.g. authentic, fresh",         required: false },
  { id: "competitors",    label: "Competitors they admire", placeholder: "e.g. @localbrasserie",          required: false },
  { id: "brandColors",    label: "Brand colours (hex)",     placeholder: "e.g. #8B2020, #F5F0E8",        required: false },
];

// ─── Helper to inject client data into prompts ───────────────────────────────
function injectClient(text, client) {
  if (!client || !client.businessName) return text;
  return text
    .replace(/\[BUSINESS NAME\]/g,   client.businessName)
    .replace(/\[NAME\]/g,            client.businessName)
    .replace(/\[CLIENT NAME\]/g,     client.ownerName || client.businessName)
    .replace(/\[OWNER NAME\]/g,      client.ownerName || "the owner")
    .replace(/\[TYPE\]/g,            client.businessType || "local business")
    .replace(/\[CITY\]/g,            client.city || "your city")
    .replace(/\[WHAT MAKES THEM SPECIAL\]/g, client.differentiator || "their unique approach")
    .replace(/\[AGE, LIFESTYLE, NEEDS\]/g,   client.targetCustomer || "local customers")
    .replace(/\[HOW THEY DESCRIBED IT\]/g,   client.brandVibe || "warm and welcoming")
    .replace(/\[WORDS TO AVOID\]/g,          client.avoidWords || "none specified")
    .replace(/\[HANDLES\]/g,                 client.competitors || "none specified")
    .replace(/\[LIST\]/g,                    client.promotions || "none specified")
    .replace(/\[DON'TS FROM \[BUSINESS NAME\] BRAND PROFILE\]/g, client.avoidWords || "words to avoid from brand profile")
    .replace(/\[DON'TS FROM.*?BRAND PROFILE\]/g, client.avoidWords || "words from brand profile")
    .replace(/\[BRAND VIBE\]/g,              client.brandVibe || "warm and inviting")
    .replace(/\[BRAND VIBE — [^\]]+\]/g,     client.brandVibe || "warm and inviting");
}

