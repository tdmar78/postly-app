                  const phaseChecked = phaseSteps.filter(s => checked[`${activeTier}-${s.num}`]).length;
                  return (
                    <div key={phase} style={{ marginBottom: 16 }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
                        <div style={{ background: color, padding: "4px 12px", borderRadius: 4, fontSize: 10, fontWeight: 700, fontFamily: "monospace", letterSpacing: 2, color: "#fff", textTransform: "uppercase" }}>
                          {phase}
                        </div>
                        <span style={{ fontSize: 11, color: MUTED, fontFamily: "monospace" }}>{phaseChecked}/{phaseSteps.length} done</span>
                      </div>
                      <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
                        {phaseSteps.map(step => {
                          const ck = `${activeTier}-${step.num}`;
                          const done = !!checked[ck];
                          return (
                            <div key={ck}
                              style={{ background: done ? "#0D1A0D" : CARD, border: `1px solid ${done ? GREEN + "55" : BORD}`, borderLeft: `3px solid ${done ? GREEN : color}`, borderRadius: "0 8px 8px 0", padding: "14px 18px", display: "flex", alignItems: "flex-start", gap: 14, cursor: "pointer", transition: "all 0.15s" }}
                              onClick={() => toggleCheck(ck)}>
                              <div style={{ width: 22, height: 22, borderRadius: 6, border: `2px solid ${done ? GREEN : color + "66"}`, background: done ? GREEN : "transparent", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0, marginTop: 1, transition: "all 0.15s" }}>
                                {done && <span style={{ color: "#fff", fontSize: 13, lineHeight: 1 }}>✓</span>}
                              </div>
                              <div style={{ flex: 1 }}>
                                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 8, flexWrap: "wrap" }}>
                                  <span style={{ fontWeight: 700, fontSize: 14, color: done ? "#4ADE80" : LIGHT, textDecoration: done ? "line-through" : "none", opacity: done ? 0.7 : 1 }}>
                                    {step.num}  {step.title}
                                  </span>
                                  <span style={{ fontSize: 11, color: MUTED, fontFamily: "monospace" }}>{step.tool} · {step.time}</span>
                                </div>
                                {!done && <p style={{ margin: "6px 0 0", fontSize: 13, color: MUTED, lineHeight: 1.5 }}>{step.what}</p>}
                              </div>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  );
                });
              })()}

              {completedSteps === totalSteps && (
                <div style={{ background: "#0D1A0D", border: `1px solid ${GREEN}55`, borderRadius: 10, padding: "20px 24px", textAlign: "center", marginTop: 8 }}>
                  <div style={{ fontSize: 28, marginBottom: 8 }}>🎉</div>
                  <div style={{ fontWeight: 700, fontSize: 16, color: "#4ADE80", marginBottom: 4 }}>All steps complete for {tc.name}!</div>
                  <div style={{ fontSize: 13, color: MUTED }}>Great work. Send the monthly report and you're done until next month.</div>
                </div>
              )}
            </div>
          )}

          {/* ── OVERVIEW TAB ── */}
          {mode !== "checklist" && activeTab === "overview" && (
            <div style={{ maxWidth: 900, margin: "0 auto", padding: "24px 20px 60px", display: "flex", flexDirection: "column", gap: 18 }}>
              {/* Tier headline */}
              <div style={{ background: CARD, border: `1px solid ${BORD}`, borderTop: `3px solid ${tc.color}`, borderRadius: "0 0 10px 10px", padding: "18px 22px" }}>
                <div style={{ fontSize: 10, color: tc.color, fontFamily: "monospace", letterSpacing: 3, textTransform: "uppercase", marginBottom: 4 }}>{tc.name} — {tc.price}/month</div>
                <div style={{ fontSize: 18, fontWeight: 700, color: LIGHT, marginBottom: 10 }}>{tier.tagline}</div>
                <p style={{ margin: 0, color: "#BBBBBB", fontSize: 14, lineHeight: 1.75 }}>{tier.description}</p>
              </div>

              {tier.addedOver && (
                <div style={{ background: CARD, border: `1px solid ${BORD}`, borderLeft: `4px solid ${tc.color}`, borderRadius: "0 8px 8px 0", padding: "16px 20px" }}>
                  <div style={{ fontSize: 10, color: tc.color, fontFamily: "monospace", letterSpacing: 3, textTransform: "uppercase", marginBottom: 10 }}>✦ Added over {tier.addedOver}</div>
                  <div style={{ display: "flex", flexDirection: "column", gap: 7 }}>
                    {tier.addedItems.map((item, i) => (
                      <div key={i} style={{ display: "flex", gap: 10 }}>
                        <span style={{ color: tc.color, flexShrink: 0 }}>+</span>
                        <span style={{ color: "#CCC", fontSize: 13.5, lineHeight: 1.5 }}>{item}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div>
                <div style={{ fontSize: 10, letterSpacing: 3, color: MUTED, fontFamily: "monospace", textTransform: "uppercase", marginBottom: 10 }}>What the client gets every month</div>
                <div style={{ background: CARD, border: `1px solid ${BORD}`, borderRadius: 10, overflow: "hidden" }}>
                  {tier.deliverables.map((d, i) => (
                    <div key={i} style={{ display: "flex", gap: 14, padding: "12px 18px", borderBottom: i < tier.deliverables.length - 1 ? `1px solid ${BORD}` : "none", alignItems: "flex-start" }}>
                      <span style={{ fontSize: 15, flexShrink: 0, marginTop: 1 }}>{d.icon}</span>
                      <div style={{ flex: 1 }}>
                        <div style={{ fontWeight: 700, fontSize: 13.5, color: LIGHT, marginBottom: 2 }}>{d.item}</div>
                        <div style={{ fontSize: 12.5, color: MUTED, lineHeight: 1.5 }}>{d.detail}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div>
                <div style={{ fontSize: 10, letterSpacing: 3, color: MUTED, fontFamily: "monospace", textTransform: "uppercase", marginBottom: 10 }}>Tech stack for this tier</div>
                <div style={{ background: CARD, border: `1px solid ${BORD}`, borderRadius: 10, overflow: "hidden" }}>
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 60px 1fr", padding: "8px 18px", borderBottom: `1px solid ${BORD}`, background: "#1E1E1E" }}>
                    {["Tool", "Cost", "Used For"].map(h => (
                      <div key={h} style={{ fontSize: 10, color: MUTED, fontFamily: "monospace", letterSpacing: 2, textTransform: "uppercase" }}>{h}</div>
                    ))}
                  </div>
                  {tier.techStack.map((t, i) => (
                    <div key={i} style={{ display: "grid", gridTemplateColumns: "1fr 60px 1fr", padding: "11px 18px", borderBottom: i < tier.techStack.length - 1 ? `1px solid ${BORD}` : "none", alignItems: "center" }}>
                      <div style={{ fontWeight: 700, fontSize: 13, color: LIGHT }}>{t.tool}</div>
                      <div style={{ fontSize: 12, color: t.cost === "$0" ? "#4ADE80" : tc.color, fontFamily: "monospace", fontWeight: 700 }}>{t.cost}</div>
                      <div style={{ fontSize: 12.5, color: "#AAA" }}>{t.role}</div>
                    </div>
                  ))}
                </div>
              </div>

              <button onClick={() => setActiveTab("workflow")}
                style={{ background: tc.color, border: "none", color: "#fff", padding: "13px 26px", borderRadius: 8, cursor: "pointer", fontSize: 13, fontWeight: 700, fontFamily: "monospace", alignSelf: "flex-start", letterSpacing: 1 }}>
                See Full Workflow →
              </button>
            </div>
          )}

          {/* ── WORKFLOW TAB ── */}
          {mode !== "checklist" && activeTab === "workflow" && (
            <div style={{ maxWidth: 900, margin: "0 auto", padding: "24px 20px 60px" }}>
              <div style={{ marginBottom: 12, color: MUTED, fontSize: 13, fontFamily: "monospace", display: "flex", gap: 16, alignItems: "center" }}>
                <span>{tier.steps.length} steps · Click any step to expand</span>
                {mode === "workspace" && hasClient && (
                  <span style={{ color: GREEN, fontSize: 11 }}>✦ Prompts auto-filled for {client.businessName}</span>
                )}
              </div>

              {(() => {
                const phases = [...new Map(tier.steps.map(s => [s.phase, { phase: s.phase, color: s.phaseColor }])).values()];
                return phases.map(({ phase, color }) => {
                  const phaseSteps = tier.steps.filter(s => s.phase === phase);
                  return (
                    <div key={phase} style={{ marginBottom: 10 }}>
                      <div style={{ background: color, padding: "5px 14px", borderRadius: "6px 6px 0 0", display: "inline-block", fontSize: 10, fontWeight: 700, fontFamily: "monospace", letterSpacing: 2, color: "#fff", textTransform: "uppercase" }}>
                        {phase}
                      </div>
                      <div style={{ display: "flex", flexDirection: "column" }}>
                        {phaseSteps.map((step, si) => {
                          const key = `${step.phase}-${step.num}`;
                          const isOpen = expandedStep === key;
                          const ck = `${activeTier}-${step.num}`;
                          const done = !!checked[ck];
                          const rawPrompt = step.prompt;
                          const displayPrompt = rawPrompt && hasClient ? injectClient(rawPrompt, client) : rawPrompt;
                          const promptId = `prompt-${activeTier}-${step.num}`;

                          return (
                            <div key={key} style={{ background: CARD, border: `1px solid ${isOpen ? color : BORD}`, borderLeft: `3px solid ${done ? GREEN : color}`, borderRadius: si === phaseSteps.length - 1 && !isOpen ? "0 0 8px 8px" : 0, overflow: "hidden", transition: "border-color 0.15s" }}>
                              <button onClick={() => setExpandedStep(isOpen ? null : key)}
                                style={{ width: "100%", background: "none", border: "none", padding: "13px 16px", cursor: "pointer", display: "flex", alignItems: "center", gap: 12, textAlign: "left" }}>
                                <div style={{ width: 26, height: 26, borderRadius: "50%", background: done ? GREEN + "22" : color + "22", border: `1px solid ${done ? GREEN + "66" : color + "66"}`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 10, color: done ? GREEN : color, fontWeight: 700, fontFamily: "monospace", flexShrink: 0 }}>
                                  {done ? "✓" : step.num}
                                </div>
                                <div style={{ flex: 1 }}>
                                  <div style={{ fontWeight: 700, fontSize: 13.5, color: LIGHT }}>{step.title}</div>
                                  <div style={{ fontSize: 11, color: MUTED, marginTop: 2, fontFamily: "monospace" }}>{step.tool} · {step.time}</div>
                                </div>
                                {mode === "checklist" && (
                                  <div onClick={e => { e.stopPropagation(); toggleCheck(ck); }}
                                    style={{ width: 20, height: 20, borderRadius: 5, border: `2px solid ${done ? GREEN : MUTED}`, background: done ? GREEN : "transparent", display: "flex", alignItems: "center", justifyContent: "center", cursor: "pointer", flexShrink: 0 }}>
                                    {done && <span style={{ color: "#fff", fontSize: 11 }}>✓</span>}
                                  </div>
                                )}
                                <div style={{ color: isOpen ? color : MUTED, fontSize: 17, transition: "transform 0.2s", transform: isOpen ? "rotate(180deg)" : "none" }}>⌄</div>
                              </button>

                              {isOpen && (
                                <div style={{ borderTop: `1px solid ${BORD}` }}>
                                  <div style={{ padding: "14px 16px 12px", borderBottom: displayPrompt ? `1px solid ${BORD}` : "none" }}>
                                    <div style={{ fontSize: 10, color: MUTED, fontFamily: "monospace", letterSpacing: 2, textTransform: "uppercase", marginBottom: 7 }}>What you do</div>
                                    <p style={{ margin: 0, color: "#CCCCCC", fontSize: 13.5, lineHeight: 1.7 }}>{step.what}</p>
                                  </div>

                                  {displayPrompt && (
                                    <div style={{ padding: "12px 16px", borderBottom: `1px solid ${BORD}` }}>
                                      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
                                        <div style={{ fontSize: 10, color: color, fontFamily: "monospace", letterSpacing: 2, textTransform: "uppercase" }}>
                                          {mode === "workspace" && hasClient ? `Prompt — filled for ${client.businessName}` : "Prompt to copy into Claude"}
                                        </div>
                                        <button onClick={() => copyPrompt(displayPrompt, promptId)}
                                          style={{ background: copied === promptId ? GREEN : "#1E1E1E", border: `1px solid ${copied === promptId ? GREEN : BORD}`, color: copied === promptId ? "#fff" : MUTED, borderRadius: 5, padding: "4px 11px", cursor: "pointer", fontSize: 11, fontFamily: "monospace", transition: "all 0.2s" }}>
                                          {copied === promptId ? "✓ Copied!" : "Copy"}
                                        </button>
                                      </div>
                                      <pre style={{ background: "#0A0A0A", border: `1px solid ${BORD}`, borderRadius: 6, padding: "13px 15px", fontSize: 11.5, color: "#AAAAAA", lineHeight: 1.65, overflowX: "auto", whiteSpace: "pre-wrap", fontFamily: "monospace", margin: 0 }}>
                                        {displayPrompt}
                                      </pre>
                                    </div>
                                  )}

                                  <div style={{ padding: "12px 16px", background: "#0F1A0F", display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 12 }}>
                                    <div style={{ flex: 1 }}>
                                      <div style={{ fontSize: 10, color: "#4ADE80", fontFamily: "monospace", letterSpacing: 2, textTransform: "uppercase", marginBottom: 7 }}>Output</div>
                                      <p style={{ margin: 0, color: "#A7F3A7", fontSize: 13, lineHeight: 1.65 }}>{step.output}</p>
                                    </div>
                                    <div onClick={() => toggleCheck(ck)}
                                      style={{ display: "flex", alignItems: "center", gap: 6, cursor: "pointer", flexShrink: 0, background: done ? GREEN + "22" : "#1E1E1E", border: `1px solid ${done ? GREEN : BORD}`, borderRadius: 6, padding: "6px 12px" }}>
                                      <div style={{ width: 16, height: 16, borderRadius: 4, border: `2px solid ${done ? GREEN : MUTED}`, background: done ? GREEN : "transparent", display: "flex", alignItems: "center", justifyContent: "center" }}>
                                        {done && <span style={{ color: "#fff", fontSize: 10 }}>✓</span>}
                                      </div>
                                      <span style={{ fontSize: 11, color: done ? "#4ADE80" : MUTED, fontFamily: "monospace" }}>{done ? "Done" : "Mark done"}</span>
                                    </div>
                                  </div>
                                </div>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  );
                });
              })()}
            </div>
          )}
        </>
      )}
    </div>
  );
}
